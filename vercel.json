{
  "headers": [
    {
      "source": "/discord-cdn/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/discord-cdn/(.*)",
      "destination": "https://cdn.discordapp.com/$1"
    }
  ]
}
